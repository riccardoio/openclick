{
  "name": "openclick",
  "version": "0.1.5",
  "description": "Run macOS desktop tasks from natural-language prompts via cua-driver.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "openclick": "bin/openclick"
  },
  "files": [
    "bin/openclick",
    "src",
    "!src/mac-app.ts",
    "docs",
    "VERSION",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src tests",
    "format": "biome format --write src tests",
    "build:mac-app": "swift build --package-path mac-app",
    "launch:mac-app": "bun src/mac-app.ts --detach"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.119",
    "@anthropic-ai/sdk": "^0.91.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openclick/cua-driver": "0.1.0",
    "@vr_patel/tui": "^1.0.0",
    "yaml": "^2.5.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  }
}
